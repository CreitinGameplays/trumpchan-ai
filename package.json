{
  "name": "vrm-viewer-starter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n vite,server,ai \"npm run dev:vite\" \"npm run dev:server\" \"npm run dev:ai\"",
    "dev:vite": "vite",
    "dev:server": "node backend/server.js",
    "dev:ai": "wait-on tcp:3000 && tsx backend/ai-server.ts",
    "dev:electron": "concurrently -n vite,server,ai,electron \"npm run dev:vite\" \"npm run dev:server\" \"npm run dev:ai\" \"npm run electron:wait\"",
    "electron:wait": "wait-on tcp:5173 && electron .",
    "electron": "electron .",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@google/generative-ai": "^0.24.1",
    "@pixiv/three-vrm": "^3.4.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "three": "^0.181.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "tsx": "^4.23.1",
    "vite": "^7.1.3",
    "wait-on": "^9.0.10"
  }
}
